# ==========================================
# LLM Model Configuration
# ==========================================

# MODEL_PROVIDER: 选择 LLM 提供商
#   - ollama        -> 本地运行的 Ollama（免费，需本地安装 Ollama）
#   - openai        -> OpenAI 官方 API（如 GPT-4o）
#   - openai_like   -> 任意兼容 OpenAI API 格式的第三方服务（如深度求索、Kimi、小米 token-plan 等）
MODEL_PROVIDER=openai_like

# MODEL_ID: 具体使用的模型 ID，根据 provider 填写对应的模型名
MODEL_ID=mimo-v2.5-pro

# OLLAMA_HOST: 本地 Ollama 服务地址（仅当 MODEL_PROVIDER=ollama 时生效）
# OLLAMA_HOST=http://localhost:11434

# OPENAI_API_KEY / OPENAI_BASE_URL:
# 当 provider 为 openai 或 openai_like 时使用。
# 若使用第三方兼容服务，将 BASE_URL 替换为对应网关地址。
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ==========================================
# Search Engine Configuration
# ==========================================

# SEARCH_PROVIDER: 选择联网搜索提供商
#   - tavily      -> Tavily AI 搜索引擎（默认，专为 AI 优化的搜索）
#   - scrapegraph -> Scrapegraph AI（侧重网页抓取与提取）
SEARCH_PROVIDER=tavily

# TAVILY_API_KEY: Tavily 搜索服务的 API Key（SEARCH_PROVIDER=tavily 时必填）
# 官网: https://tavily.com/
TAVILY_API_KEY=

# SGAI_API_KEY: Scrapegraph AI 的 API Key（SEARCH_PROVIDER=scrapegraph 且 SCRAPEGRAPH_MODE=cloud 时必填）
# SGAI = ScrapeGraph AI，用于替代 Tavily 进行网页抓取搜索
# 官网: https://dub.sh/scrapegraphai
SGAI_API_KEY=

# SCRAPEGRAPH_MODE: Scrapegraph 的运行模式（SEARCH_PROVIDER=scrapegraph 时生效）
#   - cloud -> 使用 ScrapeGraph 云端 API（需 SGAI_API_KEY）
#   - local -> 使用本地 scrapegraphai 库（需 Ollama + Playwright，零 API 费用）
# SCRAPEGRAPH_MODE=cloud

# 以下仅在 SCRAPEGRAPH_MODE=local 时生效
# SCRAPEGRAPH_LLM_MODEL=ollama/llama3.2
# SCRAPEGRAPH_LLM_BASE_URL=http://localhost:11434
# SCRAPEGRAPH_EMBEDDING_MODEL=ollama/nomic-embed-text


# ==========================================
# Optional Tavily Settings
# ==========================================

# TAVILY_SEARCH_DEPTH: 搜索深度 (basic / advanced)
# TAVILY_SEARCH_DEPTH=advanced

# TAVILY_INCLUDE_ANSWER: 是否让 Tavily 直接返回答案摘要 (true / false)
# TAVILY_INCLUDE_ANSWER=true
